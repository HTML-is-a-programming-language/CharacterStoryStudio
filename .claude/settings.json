{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdatesChannel": "stable",
  "cleanupPeriodDays": 180,
  "permissions": {
    "ask": ["Bash(git commit *)", "Bash(git push *)"],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production.local)",
      "Read(./secrets/**)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(del /s *)"
    ]
  }
}
