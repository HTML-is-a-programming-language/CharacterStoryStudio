{
  "name": "character-story-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts StoryComposition out/story.mp4",
    "generate": "tsx scripts/generate-story.ts",
    "render:generated": "remotion render src/index.ts StoryComposition out/generated.mp4 --props=src/data/generated-story.json",
    "qa": "tsx scripts/qa-check.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.290",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^22.9.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "postcss": "^8.5.20",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
